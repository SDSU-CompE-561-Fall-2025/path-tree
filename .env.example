# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=course_planner
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=course_planner

# Set this directly when you have a full connection string (e.g. from Render/Supabase)
# If set, overrides the POSTGRES_* vars above
DATABASE_URL=postgresql+asyncpg://course_planner:changeme@localhost:5432/course_planner

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-random-hex-string
REFRESH_SECRET_KEY=replace-with-different-random-hex-string

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── App ──────────────────────────────────────────────────────────────────────
# "development" uses plain HTTP cookies (for localhost)
# "production"  uses secure HTTPS-only cookies (for Render + Vercel)
ENVIRONMENT=development

# Comma-separated list of allowed frontend origins
# Local dev:  CORS_ORIGINS=http://localhost:3000
# Production: CORS_ORIGINS=https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
