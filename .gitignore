###############################################
#                PYTHON BACKEND               #
###############################################

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environment
.venv/
env/
venv/

# Python caches
.mypy_cache/
.ruff_cache/
.pytest_cache/
.tox/
.coverage
coverage.xml
htmlcov/
.pyre/
.pytype/

# Logs / temp files
*.log
*.out
*.err
*.tmp

# Build/distribution
build/
dist/
*.egg-info/
.eggs/
MANIFEST
pip-wheel-metadata/

# SQLite or local backend files
backend/*.sqlite3
backend/tmp/
backend/logs/

# Backup / swap files
*.lock
*.bak
*.swp

###############################################
#                NODE / FRONTEND              #
###############################################

# Node modules
node_modules/

# Next.js build output
.next/
out/
.next.old/

# Production build artifacts
*.map
*.cache
*.npm
.npm/
.pnp.cjs
.pnp.loader.mjs

# Environment variables for frontend
.env.local
.env.development.local
.env.test.local
.env.production.local

# Backend environment
.env

# Yarn / PNPM / Bun
yarn-error.log
yarn-debug.log*
pnpm-debug.log*
bun.lockb

# Expo or React Native (if ever used)
.expo/
.expo-shared/

###############################################
#       FRONTEND TOOLS / PACKAGERS            #
###############################################

# Tailwind / PostCSS caches
.postcssrc
.postcss-cache/
.tailwindcss/

# TypeScript
*.tsbuildinfo

###############################################
#                  IDE / OS                   #
###############################################

# VS Code
.vscode/

# JetBrains
.idea/
*.iml

# Sublime
*.sublime-workspace
*.sublime-project

# MacOS
.DS_Store

# Windows
Thumbs.db
desktop.ini

